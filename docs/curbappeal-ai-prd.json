  "overview": {
    "vision": "Transform the way homeowners and real estate professionals approach curb appeal through AI-powered visual analysis and actionable recommendations.",
    "mission": "Help every property reach its maximum market appeal potential by providing instant, professional-grade curb appeal assessments and detailed improvement roadmaps.",
    "problem_statement": "Many homes sit on the market longer than necessary because owners and realtors lack professional guidance on which exterior improvements would have the greatest impact on curb appeal and market value.",
    "target_market": ["homeowners_selling", "real_estate_agents", "property_investors", "home_improvement_contractors"]
  },
  "user_personas": [
    {
      "name": "Sarah the Seller",
      "description": "Homeowner preparing to sell",
      "pain_points": ["Doesn't know which improvements to prioritize", "Limited budget for improvements", "Wants maximum ROI on investments"],
      "goals": ["Sell home quickly", "Maximize sale price", "Invest improvement budget wisely"]
    },
    {
      "name": "Mike the Realtor",
      "description": "Real estate agent helping clients",
      "pain_points": ["Needs professional recommendations for clients", "Time-consuming to assess multiple properties", "Wants data-driven advice"],
      "goals": ["Help clients sell faster", "Provide professional value", "Stand out from competitors"]
    },
    {
      "name": "Jennifer the Investor",
      "description": "Property investor evaluating acquisitions",
