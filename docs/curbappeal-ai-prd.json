        "User uploads home exterior photo",
        "AI analyzes image across 10 criteria",
        "System generates score (X/50 points)",
        "User receives instant feedback with positive lead-in and direct recommendations"
      ],
      "technical_requirements": [
        "Image upload with drag & drop interface",
        "OpenAI GPT-4 Vision API integration",
        "Real-time analysis (< 30 seconds)",
        "Responsive scoring display"
      ]
    },
    "email_capture": {
      "description": "Convert users to detailed analysis with email collection",
      "user_flow": [
        "User completes instant analysis",
        "System offers comprehensive report",
        "User enters email for detailed analysis",
        "Email confirmation sent"
      ],
      "technical_requirements": [
        "Email validation and storage",
        "Automated email confirmation",
        "Integration with report generation system"
      ]
    },
    "multi_photo_upload": {
      "description": "Collect additional property angles for comprehensive analysis",
